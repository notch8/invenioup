[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[dev-packages]
check-manifest = ">=0.25"

[packages]
python-dotenv = ">=1.0.0"
invenio-app-rdm = {extras = ["opensearch2", "s3"], version = "~=13.0.0"}
invenioup = {editable = true, path = "./site"}
uwsgi = ">=2.0"
uwsgitop = ">=0.11"
uwsgi-tools = ">=1.1.1"
setuptools = "<82"

[requires]
python_version = "3.9"

[pipenv]
allow_prereleases = false
