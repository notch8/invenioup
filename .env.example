# Copy to .env before running Docker Compose or local Invenio commands:
#   cp .env.example .env
#
# Docker Compose reads this file for variable substitution and passes it to app
# containers. invenio.cfg loads the same file from the repo root via python-dotenv
# when you run Invenio outside Docker.

# ── PostgreSQL (must match INVENIO_SQLALCHEMY_DATABASE_URI) ───────────
POSTGRES_USER=invenioup
POSTGRES_PASSWORD=invenioup
POSTGRES_DB=invenioup
INVENIO_SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://invenioup:invenioup@db/invenioup

# ── Flask / session security ─────────────────────────────────────────
INVENIO_SECRET_KEY=change-me-generate-a-long-random-string-for-production

# ── First-boot admin user (docker/entrypoint.sh when INVENIO_AUTO_INIT=true) ─
INVENIO_ADMIN_EMAIL=admin@notch8.com
INVENIO_ADMIN_PASSWORD=changeme123

# ── MinIO (S3) — use the same values for INVENIO_S3_* in local dev ─────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-secret
INVENIO_S3_ENDPOINT_URL=http://s3:9000/
INVENIO_S3_ACCESS_KEY_ID=minioadmin
INVENIO_S3_SECRET_ACCESS_KEY=minioadmin-secret

# ── OpenSearch initial admin (only relevant if you enable the security plugin)
OPENSEARCH_INITIAL_ADMIN_PASSWORD=changeme-opensearch-admin

# ── pgAdmin ───────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=info@notch8.com
PGADMIN_DEFAULT_PASSWORD=invenioup

# ── Public URLs (Traefik / Stack Car) ─────────────────────────────────
INVENIO_SITE_UI_URL=https://invenioup.localhost.direct
INVENIO_SITE_API_URL=https://invenioup.localhost.direct/api

# ── Celery / Redis / OpenSearch (Docker Compose service hostnames) ────
INVENIO_ACCOUNTS_SESSION_REDIS_URL=redis://cache:6379/1
INVENIO_CACHE_REDIS_URL=redis://cache:6379/0
INVENIO_CACHE_TYPE=redis
INVENIO_COMMUNITIES_IDENTITIES_CACHE_REDIS_URL=redis://cache:6379/4
INVENIO_BROKER_URL=amqp://guest:guest@mq:5672/
INVENIO_CELERY_BROKER_URL=amqp://guest:guest@mq:5672/
INVENIO_CELERY_RESULT_BACKEND=redis://cache:6379/2
INVENIO_RATELIMIT_STORAGE_URL=redis://cache:6379/3
INVENIO_SEARCH_HOSTS=['search:9200']
INVENIO_WSGI_PROXIES=2
