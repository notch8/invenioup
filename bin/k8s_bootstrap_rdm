#!/usr/bin/env bash
# Apply RDM bootstrap steps in the cluster (supplements helm-invenio install-init job).
#
# Usage: ./bin/k8s_bootstrap_rdm RELEASE_NAME NAMESPACE
#
# Optional env (passed into the pod):
#   INVENIO_ADMIN_EMAIL
#
set -euo pipefail

if [[ -z "${1:-}" ]] || [[ -z "${2:-}" ]]; then
  echo "usage: $0 RELEASE_NAME NAMESPACE" >&2
  echo "example: $0 invenioup-friends invenioup-friends" >&2
  exit 1
fi

release_name="$1"
namespace="$2"
deploy="${release_name}-web"

kubectl rollout status "deployment/${deploy}" -n "${namespace}" --timeout=5m

exec kubectl exec -n "${namespace}" "deploy/${deploy}" -c web -- \
  env INVENIO_ADMIN_EMAIL="${INVENIO_ADMIN_EMAIL}" \
  /usr/local/bin/invenio-k8s-rdm-bootstrap
